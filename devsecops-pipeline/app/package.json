{
  "name": "devsecops-demo-app",
  "version": "1.0.0",
  "description": "Demo Node.js app for DevSecOps pipeline",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "dev": "nodemon src/index.js",
    "test": "jest --coverage --forceExit",
    "test:ci": "jest --coverage --forceExit --ci",
    "lint": "eslint src/ --ext .js"
  },
  "dependencies": {
    "express": "4.18.2",
    "helmet": "7.1.0",
    "morgan": "1.10.0"
  },
  "devDependencies": {
    "jest": "29.7.0",
    "supertest": "6.3.4",
    "eslint": "8.57.0",
    "nodemon": "3.0.3"
  },
  "jest": {
    "testEnvironment": "node",
    "coverageThreshold": {
      "global": {
        "branches": 50,
        "functions": 50,
        "lines": 50,
        "statements": 50
      }
    }
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
